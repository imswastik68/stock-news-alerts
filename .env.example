INFERENCE_BACKEND=groq
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Only needed for fetch_telegram_history.py (reading back sent alerts).
# Create at https://my.telegram.org -> API development tools. Reusable from stock_selector.
TG_API_ID=
TG_API_HASH=

NEWSAPI_API_KEY=
NEWSAPI_DAILY_CAP=90

# market_wide = all NSE filings, market-wide, high-impact filtered (recommended).
# watchlist   = only your watchlist.yaml tickers, + Google/NewsAPI/RSS media.
COVERAGE_MODE=market_wide
# Near-real-time polling of the exchange feed. 2 min is the free-tier sweet spot.
POLL_INTERVAL_MINUTES=2
ALERT_CONFIDENCE_THRESHOLD=0.70
MIN_MATERIALITY_SCORE=0.65
MIN_SOURCE_QUALITY_FOR_ALERTS=0.55
MAX_ARTICLES_PER_CYCLE=18
MAX_GOOGLE_NEWS_PER_TICKER=8
# Only articles newer than this are considered; also sets the Google News when:Nd window.
MAX_NEWS_AGE_HOURS=48
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=18

DB_PATH=stock_news.db
DRY_RUN=true
LOG_LEVEL=INFO
